# Local-only paths used by optional research and benchmark scripts.
# Copy this file to .env and set the paths for your machine.

GWR_ALLENK_ROOT=/path/to/GeminiWatermarkTool
GWR_SAMPLE_ROOT=/path/to/sample-files/gemini-watermark
GWR_VIDEO_SAMPLE_ROOT=/path/to/sample-files/gemini-video-watermark
GWR_DOWNLOAD_SAMPLE_ROOT=/path/to/downloaded-gemini-samples
